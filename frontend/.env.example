# Copy to `.env.local` for local development (never commit secrets)

# Local dev — Vite dev server proxies /api → localhost:3000 (see vite.config.ts)
VITE_API_URL=/api
VITE_WS_URL=http://localhost:3000

# Production build — set in repo root `.env`, used by deploy/deploy.sh
# VITE_API_URL=/api
# VITE_WS_URL=
