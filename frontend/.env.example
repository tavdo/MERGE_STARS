VITE_API_URL=http://localhost:3000
VITE_WS_URL=http://localhost:3000

# Copy to `.env.local` (never commit real secrets)

# Local NestJS API (run: cd backend && npm run start:dev)
VITE_API_URL=http://localhost:3000/api/v1
VITE_WS_URL=http://localhost:3000

# Production Laravel API (after routes are deployed — see docs/LARAVEL_API_ROUTES.md)
# VITE_API_URL=https://api.mergestars.one/api/v1
# VITE_WS_URL=https://api.mergestars.one

# Optional: public endpoints if they differ from authenticated API base
# VITE_PUBLIC_API_URL=https://api.mergestars.one/api
