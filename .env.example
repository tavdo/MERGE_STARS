# ─────────────────────────────────────────────────────────────────────────────
# MERGE STARS — Linux VPS production environment
# On your server: cp .env.example .env  then edit values
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite build — baked into static bundle at deploy time) ──
VITE_API_URL=/api
# Leave empty to use same origin (nginx proxies /socket.io/ to backend)
VITE_WS_URL=

# Optional Sentry (frontend)
# VITE_SENTRY_DSN=
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Backend (runtime — read by systemd merge-stars-backend.service) ──
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://mergestars.com

# ── PostgreSQL ──
DATABASE_URL=postgresql://merge_stars:CHANGE_ME@127.0.0.1:5432/merge_stars
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=merge_stars
DB_PASSWORD='CHANGE_ME'
DB_NAME=merge_stars
# true = auto-sync schema (dev/small deploys). false + DB_MIGRATE=true for production migrations
DB_SYNC=true
DB_MIGRATE=false
DB_SSL=false

# ── JWT / Auth ──
JWT_SECRET=change-this-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_DAYS=7
# Set false to skip email verification on register (local dev only)
EMAIL_VERIFY=true

# ── Error tracking (optional) ──
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Email (production VPS: Brevo HTTPS — SMTP blocked on DigitalOcean) ──
# https://www.brevo.com → SMTP & API → API Keys (xkeysib-...)
# Authenticate mergestars.com in Brevo → Domains; add VPS IP in Security → Authorized IPs
# GitHub secret: BREVO_API_KEY
BREVO_API_KEY=
MAIL_FROM=MERGE STARS <noreply@mergestars.com>
SMTP_USER=mergestars01@gmail.com

# ── SMTP (local dev / if VPS allows outbound 587) ──
# Without SMTP, emails log as [MAIL-DEV] in backend journal
SMTP_HOST=smtp.gmail.com
# Use 587 on VPS (465 often blocked); 465 works locally for some networks
SMTP_PORT=587
# SMTP_TIMEOUT_MS=15000
# Must match the Gmail account where the App Password was created
SMTP_USER=mergestars01@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM=MERGE STARS <mergestars01@gmail.com>

# ── File uploads (KYC documents) ──
UPLOAD_DIR=/var/www/merge-stars/uploads

# ── Admin account (seed on empty DB, or reset via deploy/reset-admin-password.sh) ──
SEED_ADMIN_EMAIL=admin@mergestars.com
SEED_ADMIN_PASSWORD=your-secure-admin-password
# Set true once to apply SEED_ADMIN_PASSWORD on backend start, then remove
# SEED_ADMIN_SYNC=true

# ── Bulk announcement script (deploy/announce-users.sh) ──
# ANNOUNCE_LANG=ka
# ANNOUNCE_EMAIL_DELAY_MS=600
