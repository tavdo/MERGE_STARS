# ─────────────────────────────────────────────────────────────────────────────
# MERGE STARS — Linux VPS production environment
# On your server: cp .env.example .env  then edit values
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite build — baked into static bundle at deploy time) ──
VITE_API_URL=/api
VITE_WS_URL=

# ── Backend (runtime — read by systemd merge-stars-backend.service) ──
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://mergestars.com

# ── PostgreSQL ──
# Full URL (preferred) OR individual fields below
DATABASE_URL=postgresql://merge_stars:mergestars12%23@127.0.0.1:5432/merge_stars
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=merge_stars
# Use quotes if password contains # or other special shell characters
DB_PASSWORD='mergestars12#'
DB_NAME=merge_stars
DB_SYNC=true
DB_SSL=false

# ── JWT / Auth ──
JWT_SECRET=change-this-to-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_DAYS=7

# ── SMTP (email verification + forgot password) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM='MERGE STARS <noreply@mergestars.com>'

# ── First admin (created once if no user with this email exists) ──
SEED_ADMIN_EMAIL=admin@mergestars.com
SEED_ADMIN_PASSWORD=Admin123!ChangeMe
