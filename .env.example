# ─────────────────────────────────────────────────────────────────────────────
# MERGE STARS — Linux VPS production environment
# On your server: cp .env.example .env  then edit FRONTEND_URL
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite build — baked into static bundle at deploy time) ──
# Use /api when nginx proxies API requests to the backend on the same host.
VITE_API_URL=/api

# Leave empty for WebSocket on the same origin as the website.
# Example separate API host: VITE_WS_URL=https://api.yourdomain.com
VITE_WS_URL=

# ── Backend (runtime — read by systemd merge-stars-backend.service) ──
NODE_ENV=production
PORT=3000

# Comma-separated browser origins for CORS (how users open the site).
# Examples:
#   https://yourdomain.com
#   https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=https://yourdomain.com
