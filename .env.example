# ─────────────────────────────────────────────────────────────────────────────
# MERGE STARS — production / Docker Compose environment
# Copy to `.env` in the repo root on your VPS:
#   cp .env.example .env
# Never commit `.env` (contains your real domain).
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite build args — baked into the static bundle at build time) ──
# Use relative /api when nginx in the frontend container proxies to the backend.
# Use a full URL only if the API is hosted on a separate domain.
VITE_API_URL=/api

# Leave empty to connect WebSocket to the same origin as the website.
# Example for separate API host: VITE_WS_URL=https://api.yourdomain.com
VITE_WS_URL=

# ── Backend (runtime) ──
NODE_ENV=production
PORT=3000

# Comma-separated allowed browser origins for CORS (must match how users open the site).
# Examples:
#   https://yourdomain.com
#   https://yourdomain.com,https://www.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── Docker Compose (host port mapping) ──
FRONTEND_PORT=8080
BACKEND_PORT=3000

# Optional project name (docker compose -p)
COMPOSE_PROJECT_NAME=merge-stars
